# Copy to `.env` and adjust. `.env` is gitignored.
# Config is validated at API boot — missing/invalid values fail fast.

# --- API ---
PORT=3000
NODE_ENV=development
# Allowed browser origin for CORS (dev). Prod is same-origin (no CORS).
CORS_ORIGIN=http://localhost:4200

# --- MySQL (used from Slice 3 onward) ---
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=rpn_calculator
